              cppLanguageStandard="17">
  <MAINGROUP id="tMgMain" name="ThomAndGuy">
    <GROUP id="tMgSrc" name="Source">
      <FILE id="ppCpp" name="PluginProcessor.cpp" compile="1" resource="0"
