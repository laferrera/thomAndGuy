<?xml version="1.0" encoding="UTF-8"?>

<JUCERPROJECT id="TmG001" name="ThomAndGuy" projectType="audioplug" useAppConfig="0"
              addUsingNamespaceToJuceHeader="0" jucerFormatVersion="1"
